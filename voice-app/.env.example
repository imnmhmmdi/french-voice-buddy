# Server-only — do not prefix with NEXT_PUBLIC_.
# In Vercel: Project → Settings → Environment Variables, add each for Production/Preview as needed.

# ElevenLabs API key (same key as in the ElevenLabs dashboard).
ELEVENLABS_API_KEY=

# ConvAI agent id (e.g. agent_xxx). Used only by /api/conversation-token, not sent to the browser.
ELEVENLABS_AGENT_ID=
